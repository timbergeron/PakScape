<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#FFF3F3F3</Color>
    <Color x:Key="PanelBackgroundColor">#FFFFFFFF</Color>
    <Color x:Key="PanelBorderColor">#FFE5E5E5</Color>
    <Color x:Key="TextForegroundColor">#FF1A1A1A</Color>
    <Color x:Key="MutedForegroundColor">#FF616161</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="{StaticResource PanelBorderColor}" />
    <SolidColorBrush x:Key="TextForegroundBrush" Color="{StaticResource TextForegroundColor}" />
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="{StaticResource MutedForegroundColor}" />
    <SolidColorBrush x:Key="MenuHoverBrush" Color="#0F000000" />
    <SolidColorBrush x:Key="MenuDividerBrush" Color="#20000000" />
    <SolidColorBrush x:Key="ScrollBarThumbBrush" Color="#73000000" />
    <SolidColorBrush x:Key="ScrollBarThumbHoverBrush" Color="#99000000" />
</ResourceDictionary>
