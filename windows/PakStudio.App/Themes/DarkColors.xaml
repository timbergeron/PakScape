<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="WindowBackgroundColor">#FF202020</Color>
    <Color x:Key="PanelBackgroundColor">#FF2B2B2B</Color>
    <Color x:Key="PanelBorderColor">#FF454545</Color>
    <Color x:Key="TextForegroundColor">#FFFFFFFF</Color>
    <Color x:Key="MutedForegroundColor">#FFC8C8C8</Color>

    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="{StaticResource PanelBackgroundColor}" />
    <SolidColorBrush x:Key="PanelBorderBrush" Color="{StaticResource PanelBorderColor}" />
    <SolidColorBrush x:Key="TextForegroundBrush" Color="{StaticResource TextForegroundColor}" />
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="{StaticResource MutedForegroundColor}" />
    <SolidColorBrush x:Key="AccentBrush"
                     Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}" />
    <SolidColorBrush x:Key="AccentSoftBrush"
                     Color="{DynamicResource {x:Static SystemColors.HighlightColorKey}}"
                     Opacity="0.24" />
    <SolidColorBrush x:Key="MenuHoverBrush" Color="#14FFFFFF" />
</ResourceDictionary>
