<Window x:Class="PakStudio.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About PakScape"
        Width="440"
        Height="360"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="28,24">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Border Width="120"
                    Height="120"
                    HorizontalAlignment="Center"
                    CornerRadius="18"
                    ClipToBounds="True">
                <Image Source="/PakScape;component/Assets/PakScape.png"
                       Stretch="Uniform" />
            </Border>

            <TextBlock Margin="0,12,0,0"
                       HorizontalAlignment="Center"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Text="PakScape" />

            <TextBlock Margin="0,12,0,0"
                       MaxWidth="360"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Text="Simple Quake .pak &amp; .pk3 explorer inspired by PakScape and originally developed by Peter Engström." />

            <TextBlock Margin="0,12,0,0"
                       HorizontalAlignment="Center"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       FontSize="12"
                       Text="{Binding VersionText, RelativeSource={RelativeSource AncestorType=Window}}" />

            <TextBlock Margin="0,12,0,0"
                       HorizontalAlignment="Center">
                <Hyperlink NavigateUri="https://github.com/timbergeron/PakScape"
                           RequestNavigate="ProjectLink_OnRequestNavigate">
                    github.com/timbergeron/PakScape
                </Hyperlink>
            </TextBlock>
        </StackPanel>
    </Grid>
</Window>
