<Window x:Class="PakStudio.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PakStudio.App.Converters"
        xmlns:helpers="clr-namespace:PakStudio.App.Helpers"
        xmlns:viewModels="clr-namespace:PakStudio.App.ViewModels"
        Title="{Binding WindowTitle}"
        Height="760"
        Width="1220"
        MinHeight="600"
        MinWidth="960"
        Closing="Window_OnClosing"
        Background="{DynamicResource WindowBackgroundBrush}">
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Cut}"
                        CanExecute="Cut_CanExecute"
                        Executed="Cut_Executed" />
        <CommandBinding Command="{x:Static ApplicationCommands.Copy}"
                        CanExecute="Copy_CanExecute"
                        Executed="Copy_Executed" />
        <CommandBinding Command="{x:Static ApplicationCommands.Paste}"
                        CanExecute="Paste_CanExecute"
                        Executed="Paste_Executed" />
        <CommandBinding Command="{x:Static ApplicationCommands.SelectAll}"
                        CanExecute="SelectAll_CanExecute"
                        Executed="SelectAll_Executed" />
    </Window.CommandBindings>
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewCommand}" />
        <KeyBinding Key="N" Modifiers="Control+Shift" Command="{Binding NewPk3Command}" />
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}" />
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveAsCommand}" />
        <KeyBinding Key="F2" Command="{Binding RenameCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}" />
        <KeyBinding Key="Enter" Command="{Binding OpenSelectedCommand}" />
        <KeyBinding Key="Back" Command="{Binding UpCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="Left" Modifiers="Alt" Command="{Binding BackCommand}" />
        <KeyBinding Key="Right" Modifiers="Alt" Command="{Binding ForwardCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <helpers:BindingProxy x:Key="ViewModelProxy" Data="{Binding}" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:ArchiveViewModeEqualsConverter x:Key="ArchiveViewModeEqualsConverter" />
        <converters:ArchiveViewModeToVisibilityConverter x:Key="ArchiveViewModeToVisibilityConverter" />

        <ItemsPanelTemplate x:Key="WrapItemsPanel">
            <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="LinearItemsPanel">
            <VirtualizingStackPanel />
        </ItemsPanelTemplate>

        <HierarchicalDataTemplate DataType="{x:Type viewModels:FolderTreeNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Foreground="{DynamicResource AccentBrush}"
                           Margin="0,0,8,0"
                           Text="&#xE8B7;" />
                <TextBlock Text="{Binding DisplayName}" />
            </StackPanel>
        </HierarchicalDataTemplate>

        <DataTemplate x:Key="LargeIconTemplate">
            <Border Width="128"
                    Margin="0,0,12,12"
                    Padding="12"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <Grid Width="88" Height="72" HorizontalAlignment="Center">
                        <Image Source="{Binding Thumbnail}"
                               MaxWidth="88"
                               MaxHeight="72"
                               Stretch="Uniform" />
                        <TextBlock x:Name="LargeIconGlyph"
                                   Visibility="Collapsed"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="42"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Text="{Binding IconGlyph}" />
                    </Grid>
                    <TextBlock Margin="0,10,0,0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Text="{Binding Name}" />
                    <TextBlock Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               FontSize="11"
                               Text="{Binding TypeText}" />
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                    <Setter TargetName="LargeIconGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="SmallIconTemplate">
            <Border Margin="0,0,8,8"
                    Padding="8"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <Grid Width="30" Height="30" VerticalAlignment="Center">
                        <Image Source="{Binding Thumbnail}"
                               MaxWidth="30"
                               MaxHeight="30"
                               Stretch="Uniform" />
                        <TextBlock x:Name="SmallIconGlyph"
                                   Visibility="Collapsed"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Text="{Binding IconGlyph}" />
                    </Grid>
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock Text="{Binding Name}" />
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding TypeText}" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                    <Setter TargetName="SmallIconGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="ListTemplate">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Width="20" Height="20">
                    <Image Source="{Binding Thumbnail}" Stretch="Uniform" />
                    <TextBlock x:Name="ListIconGlyph"
                               Visibility="Collapsed"
                               FontFamily="Segoe MDL2 Assets"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AccentBrush}"
                               Text="{Binding IconGlyph}" />
                </Grid>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="{Binding Name}" />
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="{Binding TypeText}" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                    <Setter TargetName="ListIconGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="DetailsTemplate">
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="1.3*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.5*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Grid Width="20" Height="20" Margin="0,0,8,0">
                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" />
                        <TextBlock x:Name="DetailsIconGlyph"
                                   Visibility="Collapsed"
                                   FontFamily="Segoe MDL2 Assets"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Text="{Binding IconGlyph}" />
                    </Grid>
                    <TextBlock Text="{Binding Name}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="{Binding TypeText}" />
                <TextBlock Grid.Column="2"
                           HorizontalAlignment="Right"
                           Text="{Binding SizeText}" />
                <TextBlock Grid.Column="3"
                           HorizontalAlignment="Right"
                           Text="{Binding ModifiedText}" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                    <Setter TargetName="DetailsIconGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="New _PAK" Command="{Binding NewCommand}" InputGestureText="Ctrl+N" />
                <MenuItem Header="New P_K3" Command="{Binding NewPk3Command}" InputGestureText="Ctrl+Shift+N" />
                <MenuItem Header="_Open..." Command="{Binding OpenCommand}" InputGestureText="Ctrl+O" />
                <MenuItem Header="Open _Recent" ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="ToolTip" Value="{Binding}" />
                            <Setter Property="Command"
                                    Value="{Binding Data.OpenRecentCommand, Source={StaticResource ViewModelProxy}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator />
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}" InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="_Add Files..." Command="{Binding AddFilesCommand}" />
                <MenuItem Header="Add _Folder..." Command="{Binding AddFolderCommand}" />
                <MenuItem Header="_Export Selected..." Command="{Binding ExportCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Cu_t" Command="{x:Static ApplicationCommands.Cut}" InputGestureText="Ctrl+X" />
                <MenuItem Header="_Copy" Command="{x:Static ApplicationCommands.Copy}" InputGestureText="Ctrl+C" />
                <MenuItem Header="_Paste" Command="{x:Static ApplicationCommands.Paste}" InputGestureText="Ctrl+V" />
                <MenuItem Header="Select _All"
                          Command="{x:Static ApplicationCommands.SelectAll}"
                          InputGestureText="Ctrl+A" />
                <Separator />
                <MenuItem Header="New _Folder..." Command="{Binding NewFolderCommand}" />
                <Separator />
                <MenuItem Header="_Rename..." Command="{Binding RenameCommand}" InputGestureText="F2" />
                <MenuItem Header="_Delete" Command="{Binding DeleteCommand}" InputGestureText="Delete" />
            </MenuItem>
            <MenuItem Header="_Go">
                <MenuItem Header="_Back" Command="{Binding BackCommand}" InputGestureText="Alt+Left" />
                <MenuItem Header="_Forward" Command="{Binding ForwardCommand}" InputGestureText="Alt+Right" />
                <Separator />
                <MenuItem Header="_Up One Level" Command="{Binding UpCommand}" InputGestureText="Backspace" />
                <MenuItem Header="_Open Selection" Command="{Binding OpenSelectedCommand}" InputGestureText="Enter" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Large Icons"
                          Command="{Binding ShowLargeIconsCommand}"
                          IsCheckable="True"
                          IsChecked="{Binding ActiveViewMode, Mode=OneWay, Converter={StaticResource ArchiveViewModeEqualsConverter}, ConverterParameter=LargeIcons}" />
                <MenuItem Header="_Small Icons"
                          Command="{Binding ShowSmallIconsCommand}"
                          IsCheckable="True"
                          IsChecked="{Binding ActiveViewMode, Mode=OneWay, Converter={StaticResource ArchiveViewModeEqualsConverter}, ConverterParameter=SmallIcons}" />
                <MenuItem Header="_List"
                          Command="{Binding ShowListCommand}"
                          IsCheckable="True"
                          IsChecked="{Binding ActiveViewMode, Mode=OneWay, Converter={StaticResource ArchiveViewModeEqualsConverter}, ConverterParameter=List}" />
                <MenuItem Header="_Details"
                          Command="{Binding ShowDetailsCommand}"
                          IsCheckable="True"
                          IsChecked="{Binding ActiveViewMode, Mode=OneWay, Converter={StaticResource ArchiveViewModeEqualsConverter}, ConverterParameter=Details}" />
                <Separator />
                <MenuItem Header="_Quick Preview"
                          InputGestureText="Space"
                          Click="QuickPreview_OnClick" />
                <Separator />
                <MenuItem Header="_Refresh" Command="{Binding RefreshCommand}" InputGestureText="F5" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="{Binding StatusText}" />
            <Separator />
            <StatusBarItem Content="{Binding CurrentFolderPath}" />
            <Separator />
            <StatusBarItem Content="{Binding SelectionStatus}" />
            <StatusBarItem HorizontalAlignment="Right"
                           Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ProgressBar Width="120" Height="8" IsIndeterminate="True" />
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="8"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <TreeView x:Name="FolderTree"
                          ItemsSource="{Binding FolderRoots}"
                          SelectedItemChanged="FolderTree_OnSelectedItemChanged" />
            </Border>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource SplitterBrush}" />

            <Border Grid.Column="2"
                    Padding="12"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Margin="0,0,0,10"
                            Padding="8,6"
                            Background="{DynamicResource AccentSoftBrush}"
                            CornerRadius="7">
                        <DockPanel>
                            <Button DockPanel.Dock="Left"
                                    Command="{Binding UpCommand}"
                                    Content="Up"
                                    Padding="8,2"
                                    Margin="0,0,10,0" />
                            <TextBox DockPanel.Dock="Right"
                                     Width="220"
                                     Padding="6,2"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Search the current folder" />
                            <TextBlock VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="{Binding CurrentFolderPath}" />
                        </DockPanel>
                    </Border>

                    <Grid DockPanel.Dock="Top"
                          Margin="0,0,0,8"
                          Visibility="{Binding ActiveViewMode, Converter={StaticResource ArchiveViewModeToVisibilityConverter}, ConverterParameter=Details}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="1.3*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Tag="Name"
                                Click="SortHeader_OnClick"
                                Margin="0"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                HorizontalContentAlignment="Left"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MutedForegroundBrush}"
                                Content="{Binding NameSortHeader}" />
                        <Button Grid.Column="1"
                                Tag="Type"
                                Click="SortHeader_OnClick"
                                Margin="0"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                HorizontalContentAlignment="Left"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MutedForegroundBrush}"
                                Content="{Binding TypeSortHeader}" />
                        <Button Grid.Column="2"
                                Tag="Size"
                                Click="SortHeader_OnClick"
                                Margin="0"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                HorizontalContentAlignment="Right"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MutedForegroundBrush}"
                                Content="{Binding SizeSortHeader}" />
                        <Button Grid.Column="3"
                                Tag="Modified"
                                Click="SortHeader_OnClick"
                                Margin="0"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                HorizontalContentAlignment="Right"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MutedForegroundBrush}"
                                Content="{Binding ModifiedSortHeader}" />
                    </Grid>

                    <ListView x:Name="ItemList"
                              ItemsSource="{Binding CurrentItems}"
                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                              SelectionMode="Extended"
                              SelectionChanged="ItemList_OnSelectionChanged"
                              MouseDoubleClick="ItemList_OnMouseDoubleClick"
                              AllowDrop="True"
                              DragOver="ItemList_OnDragOver"
                              Drop="ItemList_OnDrop"
                              PreviewMouseLeftButtonDown="ItemList_OnPreviewMouseLeftButtonDown"
                              MouseMove="ItemList_OnMouseMove"
                              PreviewKeyDown="ItemList_OnPreviewKeyDown"
                              PreviewMouseRightButtonDown="ItemList_OnPreviewMouseRightButtonDown"
                              ScrollViewer.CanContentScroll="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open"
                                          Command="{Binding Data.OpenSelectedCommand, Source={StaticResource ViewModelProxy}}" />
                                <MenuItem Header="Quick Preview"
                                          InputGestureText="Space"
                                          Click="QuickPreview_OnClick" />
                                <Separator />
                                <MenuItem Header="Cut"
                                          Command="{Binding Data.CutCommand, Source={StaticResource ViewModelProxy}}" />
                                <MenuItem Header="Copy"
                                          Command="{Binding Data.CopyCommand, Source={StaticResource ViewModelProxy}}" />
                                <MenuItem Header="Paste"
                                          Command="{Binding Data.PasteCommand, Source={StaticResource ViewModelProxy}}" />
                                <Separator />
                                <MenuItem Header="Export..."
                                          Command="{Binding Data.ExportCommand, Source={StaticResource ViewModelProxy}}" />
                                <MenuItem Header="Rename..."
                                          Command="{Binding Data.RenameCommand, Source={StaticResource ViewModelProxy}}" />
                                <MenuItem Header="Delete"
                                          Command="{Binding Data.DeleteCommand, Source={StaticResource ViewModelProxy}}" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.Style>
                            <Style TargetType="ListView">
                                <Setter Property="ItemsPanel" Value="{StaticResource LinearItemsPanel}" />
                                <Setter Property="ItemTemplate" Value="{StaticResource DetailsTemplate}" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.ActiveViewMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="LargeIcons">
                                        <Setter Property="ItemsPanel" Value="{StaticResource WrapItemsPanel}" />
                                        <Setter Property="ItemTemplate" Value="{StaticResource LargeIconTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.ActiveViewMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="SmallIcons">
                                        <Setter Property="ItemsPanel" Value="{StaticResource WrapItemsPanel}" />
                                        <Setter Property="ItemTemplate" Value="{StaticResource SmallIconTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.ActiveViewMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="List">
                                        <Setter Property="ItemsPanel" Value="{StaticResource LinearItemsPanel}" />
                                        <Setter Property="ItemTemplate" Value="{StaticResource ListTemplate}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.ActiveViewMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="Details">
                                        <Setter Property="ItemsPanel" Value="{StaticResource LinearItemsPanel}" />
                                        <Setter Property="ItemTemplate" Value="{StaticResource DetailsTemplate}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.Style>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
