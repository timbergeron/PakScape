<Window x:Class="PakStudio.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PakStudio.App.Converters"
        xmlns:helpers="clr-namespace:PakStudio.App.Helpers"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:viewModels="clr-namespace:PakStudio.App.ViewModels"
        Title="{Binding WindowTitle}"
        Height="760"
        Width="1220"
        MinHeight="600"
        MinWidth="960"
        Closing="Window_OnClosing"
        Background="{DynamicResource WindowBackgroundBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Cut}"
                        CanExecute="Cut_CanExecute"
                        Executed="Cut_Executed" />
        <CommandBinding Command="{x:Static ApplicationCommands.Copy}"
                        CanExecute="Copy_CanExecute"
                        Executed="Copy_Executed" />
        <CommandBinding Command="{x:Static ApplicationCommands.Paste}"
                        CanExecute="Paste_CanExecute"
                        Executed="Paste_Executed" />
        <CommandBinding Command="{x:Static ApplicationCommands.SelectAll}"
                        CanExecute="SelectAll_CanExecute"
                        Executed="SelectAll_Executed" />
    </Window.CommandBindings>
    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewCommand}" />
        <KeyBinding Key="N" Modifiers="Control+Shift" Command="{Binding NewPk3Command}" />
        <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenCommand}" />
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}" />
        <KeyBinding Key="S" Modifiers="Control+Shift" Command="{Binding SaveAsCommand}" />
        <KeyBinding Key="F2" Command="{Binding RenameCommand}" />
        <KeyBinding Key="Delete" Command="{Binding DeleteCommand}" />
        <KeyBinding Key="Enter" Command="{Binding OpenSelectedCommand}" />
        <KeyBinding Key="Back" Command="{Binding UpCommand}" />
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
        <KeyBinding Key="Left" Modifiers="Alt" Command="{Binding BackCommand}" />
        <KeyBinding Key="Right" Modifiers="Alt" Command="{Binding ForwardCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <helpers:BindingProxy x:Key="ViewModelProxy" Data="{Binding}" />
        <converters:ArchiveViewModeEqualsConverter x:Key="ArchiveViewModeEqualsConverter" />
        <converters:ArchiveViewModeToVisibilityConverter x:Key="ArchiveViewModeToVisibilityConverter" />

        <Style x:Key="NavigationButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,1,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CaptionButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource MenuHoverBrush}" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource PanelBorderBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseCaptionButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource CaptionButtonStyle}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFC42B1C" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#FFB1170C" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <ItemsPanelTemplate x:Key="WrapItemsPanel">
            <WrapPanel Orientation="Horizontal" />
        </ItemsPanelTemplate>

        <ItemsPanelTemplate x:Key="LinearItemsPanel">
            <VirtualizingStackPanel />
        </ItemsPanelTemplate>

        <HierarchicalDataTemplate DataType="{x:Type viewModels:FolderTreeNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal">
                <Path Width="16"
                      Height="13"
                      Margin="0,0,8,0"
                      Data="M 1,4 L 1,14 L 19,14 L 19,5 L 9,5 L 7,2 L 1,2 Z"
                      Fill="Transparent"
                      Stroke="{DynamicResource MutedForegroundBrush}"
                      StrokeLineJoin="Round"
                      StrokeThickness="1.25"
                      Stretch="Uniform"
                      VerticalAlignment="Center" />
                <TextBlock Text="{Binding DisplayName}" />
            </StackPanel>
        </HierarchicalDataTemplate>

        <DataTemplate x:Key="LargeIconTemplate">
            <Border x:Name="LargeIconBorder"
                    Width="128"
                    Margin="0,0,12,12"
                    Padding="12"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="10">
                <StackPanel>
                    <Grid Width="88" Height="72" HorizontalAlignment="Center">
                        <Image Source="{Binding Thumbnail}"
                               MaxWidth="88"
                               MaxHeight="72"
                               Stretch="Uniform" />
                        <TextBlock x:Name="LargeIconGlyph"
                                   Visibility="Collapsed"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="42"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding IconGlyph}" />
                        <Path x:Name="LargeFolderGlyph"
                              Width="48"
                              Height="36"
                              Visibility="Collapsed"
                              Data="M 1,4 L 1,14 L 19,14 L 19,5 L 9,5 L 7,2 L 1,2 Z"
                              Fill="Transparent"
                              Stroke="{DynamicResource MutedForegroundBrush}"
                              StrokeLineJoin="Round"
                              StrokeThickness="1.25"
                              Stretch="Uniform" />
                    </Grid>
                    <TextBlock Margin="0,10,0,0"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               Text="{Binding Name}" />
                    <TextBlock Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               FontSize="11"
                               Text="{Binding TypeText}" />
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                    <Setter TargetName="LargeIconGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                    <Setter TargetName="LargeIconGlyph" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="LargeFolderGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}"
                             Value="True">
                    <Setter TargetName="LargeIconBorder"
                            Property="BorderBrush"
                            Value="{DynamicResource TextForegroundBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="SmallIconTemplate">
            <Border x:Name="SmallIconBorder"
                    Margin="0,0,8,8"
                    Padding="8"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel Orientation="Horizontal">
                    <Grid Width="30" Height="30" VerticalAlignment="Center">
                        <Image Source="{Binding Thumbnail}"
                               MaxWidth="30"
                               MaxHeight="30"
                               Stretch="Uniform" />
                        <TextBlock x:Name="SmallIconGlyph"
                                   Visibility="Collapsed"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="18"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding IconGlyph}" />
                        <Path x:Name="SmallFolderGlyph"
                              Width="20"
                              Height="16"
                              Visibility="Collapsed"
                              Data="M 1,4 L 1,14 L 19,14 L 19,5 L 9,5 L 7,2 L 1,2 Z"
                              Fill="Transparent"
                              Stroke="{DynamicResource MutedForegroundBrush}"
                              StrokeLineJoin="Round"
                              StrokeThickness="1.25"
                              Stretch="Uniform" />
                    </Grid>
                    <StackPanel Margin="8,0,0,0">
                        <TextBlock Text="{Binding Name}" />
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding TypeText}" />
                    </StackPanel>
                </StackPanel>
            </Border>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                    <Setter TargetName="SmallIconGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                    <Setter TargetName="SmallIconGlyph" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="SmallFolderGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListViewItem}}"
                             Value="True">
                    <Setter TargetName="SmallIconBorder"
                            Property="BorderBrush"
                            Value="{DynamicResource TextForegroundBrush}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="ListTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Width="20" Height="20">
                    <Image Source="{Binding Thumbnail}" Stretch="Uniform" />
                    <TextBlock x:Name="ListIconGlyph"
                               Visibility="Collapsed"
                               FontFamily="Segoe MDL2 Assets"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               Text="{Binding IconGlyph}" />
                    <Path x:Name="ListFolderGlyph"
                          Width="16"
                          Height="13"
                          Visibility="Collapsed"
                          Data="M 1,4 L 1,14 L 19,14 L 19,5 L 9,5 L 7,2 L 1,2 Z"
                          Fill="Transparent"
                          Stroke="{DynamicResource MutedForegroundBrush}"
                          StrokeLineJoin="Round"
                          StrokeThickness="1.25"
                          Stretch="Uniform" />
                </Grid>
                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Text="{Binding Name}" />
                <TextBlock Grid.Column="2"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="{Binding TypeText}" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                    <Setter TargetName="ListIconGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                    <Setter TargetName="ListIconGlyph" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="ListFolderGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate x:Key="DetailsTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="1.3*" />
                    <ColumnDefinition Width="1*" />
                    <ColumnDefinition Width="1.5*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Grid Width="20" Height="20" Margin="0,0,8,0">
                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" />
                        <TextBlock x:Name="DetailsIconGlyph"
                                   Visibility="Collapsed"
                                   FontFamily="Segoe MDL2 Assets"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="{Binding IconGlyph}" />
                        <Path x:Name="DetailsFolderGlyph"
                              Width="16"
                              Height="13"
                              Visibility="Collapsed"
                              Data="M 1,4 L 1,14 L 19,14 L 19,5 L 9,5 L 7,2 L 1,2 Z"
                              Fill="Transparent"
                              Stroke="{DynamicResource MutedForegroundBrush}"
                              StrokeLineJoin="Round"
                              StrokeThickness="1.25"
                              Stretch="Uniform" />
                    </Grid>
                    <TextBlock Text="{Binding Name}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="{Binding TypeText}" />
                <TextBlock Grid.Column="2"
                           HorizontalAlignment="Right"
                           Text="{Binding SizeText}" />
                <TextBlock Grid.Column="3"
                           HorizontalAlignment="Right"
                           Text="{Binding ModifiedText}" />
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding Thumbnail}" Value="{x:Null}">
                    <Setter TargetName="DetailsIconGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsFolder}" Value="True">
                    <Setter TargetName="DetailsIconGlyph" Property="Visibility" Value="Collapsed" />
                    <Setter TargetName="DetailsFolderGlyph" Property="Visibility" Value="Visible" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{DynamicResource WindowBackgroundBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="1">
    <DockPanel>
        <Grid DockPanel.Dock="Top"
              Height="44"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Image Grid.Column="0"
                   Width="20"
                   Height="20"
                   Margin="10,0,7,0"
                   Source="/PakScape;component/Assets/PakScape.png"
                   Stretch="Uniform" />

            <Button Grid.Column="1"
                    Style="{StaticResource NavigationButtonStyle}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Click="FolderPaneToggle_OnClick"
                    ToolTip="Show or hide folders">
                <Grid Width="12" Height="10">
                    <Border BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            BorderThickness="1"
                            CornerRadius="2" />
                    <Border Width="1"
                            Margin="4,1,0,1"
                            HorizontalAlignment="Left"
                            Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                </Grid>
            </Button>

            <Button Grid.Column="2"
                    Style="{StaticResource NavigationButtonStyle}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Command="{Binding BackCommand}"
                    ToolTip="Back">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="11"
                           Text="&#xE72B;" />
            </Button>

            <Button Grid.Column="3"
                    Style="{StaticResource NavigationButtonStyle}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Command="{Binding ForwardCommand}"
                    ToolTip="Forward">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="11"
                           Text="&#xE72A;" />
            </Button>

            <Menu Grid.Column="4"
                  VerticalAlignment="Center"
                  Background="Transparent"
                  shell:WindowChrome.IsHitTestVisibleInChrome="True">
            <MenuItem Header="_File">
                <MenuItem Header="New _PAK" Command="{Binding NewCommand}" InputGestureText="Ctrl+N" />
                <MenuItem Header="New P_K3" Command="{Binding NewPk3Command}" InputGestureText="Ctrl+Shift+N" />
                <MenuItem Header="_Open..." Command="{Binding OpenCommand}" InputGestureText="Ctrl+O" />
                <MenuItem Header="Open _Recent" ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem" BasedOn="{StaticResource {x:Type MenuItem}}">
                            <Setter Property="Header" Value="{Binding}" />
                            <Setter Property="ToolTip" Value="{Binding}" />
                            <Setter Property="Command"
                                    Value="{Binding Data.OpenRecentCommand, Source={StaticResource ViewModelProxy}}" />
                            <Setter Property="CommandParameter" Value="{Binding}" />
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator />
                <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGestureText="Ctrl+S" />
                <MenuItem Header="Save _As..." Command="{Binding SaveAsCommand}" InputGestureText="Ctrl+Shift+S" />
                <Separator />
                <MenuItem Header="_Add Files..." Command="{Binding AddFilesCommand}" />
                <MenuItem Header="Add _Folder..." Command="{Binding AddFolderCommand}" />
                <MenuItem Header="_Export Selected..." Command="{Binding ExportCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="Cu_t" Command="{x:Static ApplicationCommands.Cut}" InputGestureText="Ctrl+X" />
                <MenuItem Header="_Copy" Command="{x:Static ApplicationCommands.Copy}" InputGestureText="Ctrl+C" />
                <MenuItem Header="_Paste" Command="{x:Static ApplicationCommands.Paste}" InputGestureText="Ctrl+V" />
                <MenuItem Header="Select _All"
                          Command="{x:Static ApplicationCommands.SelectAll}"
                          InputGestureText="Ctrl+A" />
                <Separator />
                <MenuItem Header="New _Folder..." Command="{Binding NewFolderCommand}" />
                <Separator />
                <MenuItem Header="_Rename..." Command="{Binding RenameCommand}" InputGestureText="F2" />
                <MenuItem Header="_Delete" Command="{Binding DeleteCommand}" InputGestureText="Delete" />
            </MenuItem>
            <MenuItem Header="_Go">
                <MenuItem Header="_Back" Command="{Binding BackCommand}" InputGestureText="Alt+Left" />
                <MenuItem Header="_Forward" Command="{Binding ForwardCommand}" InputGestureText="Alt+Right" />
                <Separator />
                <MenuItem Header="_Up One Level" Command="{Binding UpCommand}" InputGestureText="Backspace" />
                <MenuItem Header="_Open Selection" Command="{Binding OpenSelectedCommand}" InputGestureText="Enter" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Large Icons"
                          Command="{Binding ShowLargeIconsCommand}"
                          IsCheckable="True"
                          IsChecked="{Binding ActiveViewMode, Mode=OneWay, Converter={StaticResource ArchiveViewModeEqualsConverter}, ConverterParameter=LargeIcons}" />
                <MenuItem Header="_Small Icons"
                          Command="{Binding ShowSmallIconsCommand}"
                          IsCheckable="True"
                          IsChecked="{Binding ActiveViewMode, Mode=OneWay, Converter={StaticResource ArchiveViewModeEqualsConverter}, ConverterParameter=SmallIcons}" />
                <MenuItem Header="_List"
                          Command="{Binding ShowListCommand}"
                          IsCheckable="True"
                          IsChecked="{Binding ActiveViewMode, Mode=OneWay, Converter={StaticResource ArchiveViewModeEqualsConverter}, ConverterParameter=List}" />
                <MenuItem Header="_Details"
                          Command="{Binding ShowDetailsCommand}"
                          IsCheckable="True"
                          IsChecked="{Binding ActiveViewMode, Mode=OneWay, Converter={StaticResource ArchiveViewModeEqualsConverter}, ConverterParameter=Details}" />
                <Separator />
                <MenuItem Header="_Quick Preview"
                          InputGestureText="Space"
                          Click="QuickPreview_OnClick" />
                <Separator />
                <MenuItem Header="_Refresh" Command="{Binding RefreshCommand}" InputGestureText="F5" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Command="{Binding AboutCommand}" />
            </MenuItem>
            </Menu>

            <Button Grid.Column="6"
                    Style="{StaticResource CaptionButtonStyle}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Command="{x:Static SystemCommands.MinimizeWindowCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    ToolTip="Minimize">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="10"
                           Text="&#xE921;" />
            </Button>

            <Button Grid.Column="7"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Command="{x:Static SystemCommands.MaximizeWindowCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    ToolTip="Maximize">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}"
                                         Value="Maximized">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="10"
                           Text="&#xE922;" />
            </Button>

            <Button Grid.Column="7"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Command="{x:Static SystemCommands.RestoreWindowCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    ToolTip="Restore Down">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource CaptionButtonStyle}">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding WindowState, RelativeSource={RelativeSource AncestorType=Window}}"
                                         Value="Maximized">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="10"
                           Text="&#xE923;" />
            </Button>

            <Button Grid.Column="8"
                    Style="{StaticResource CloseCaptionButtonStyle}"
                    shell:WindowChrome.IsHitTestVisibleInChrome="True"
                    Command="{x:Static SystemCommands.CloseWindowCommand}"
                    CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                    ToolTip="Close">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="10"
                           Text="&#xE8BB;" />
            </Button>
        </Grid>

        <Grid Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="FolderPaneColumn" Width="280" />
                <ColumnDefinition x:Name="FolderSplitterColumn" Width="6" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Padding="8"
                    Background="{DynamicResource WindowBackgroundBrush}"
                    BorderThickness="0"
                    CornerRadius="0">
                <TreeView x:Name="FolderTree"
                          ItemsSource="{Binding FolderRoots}"
                          SelectedItemChanged="FolderTree_OnSelectedItemChanged" />
            </Border>

            <GridSplitter x:Name="FolderSplitter"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="Transparent"
                          DragCompleted="FolderSplitter_OnDragCompleted"
                          DragStarted="FolderSplitter_OnDragStarted"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns" />

            <Border x:Name="ContentPaneBorder"
                    Grid.Column="2"
                    Padding="12"
                    Background="{DynamicResource PanelBackgroundBrush}"
                    BorderBrush="{DynamicResource PanelBorderBrush}"
                    BorderThickness="1,1,0,0"
                    CornerRadius="12,0,0,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top"
                            Margin="0,0,0,10"
                            Padding="0,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="32" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Column="0"
                                       Grid.Row="0"
                                       Margin="0,0,16,0"
                                       VerticalAlignment="Center"
                                       FontWeight="SemiBold"
                                       Text="{Binding ArchiveDisplayName}"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.RenderTransform>
                                    <TranslateTransform Y="-1" />
                                </TextBlock.RenderTransform>
                            </TextBlock>

                            <Border Grid.Column="1"
                                    Grid.Row="0"
                                    Width="260"
                                    Height="32"
                                    Background="{DynamicResource PanelBackgroundBrush}"
                                    BorderBrush="{DynamicResource PanelBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <Grid>
                                    <TextBox x:Name="ArchiveSearchBox"
                                             Padding="10,4,34,4"
                                             VerticalContentAlignment="Center"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="{Binding SearchPlaceholder}" />
                                    <TextBlock Margin="11,0,34,0"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               IsHitTestVisible="False"
                                               Text="{Binding SearchPlaceholder}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=ArchiveSearchBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Margin="0,0,10,0"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="14"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               IsHitTestVisible="False"
                                               Text="&#xE721;">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSearchActive}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <Button HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Click="ClearSearch_OnClick"
                                            ToolTip="Clear search">
                                        <Button.Style>
                                            <Style TargetType="Button"
                                                   BasedOn="{StaticResource {x:Type Button}}">
                                                <Setter Property="Width" Value="28" />
                                                <Setter Property="Height" Value="28" />
                                                <Setter Property="Margin" Value="0,0,2,0" />
                                                <Setter Property="Padding" Value="0" />
                                                <Setter Property="Background" Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSearchActive}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                        <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="10"
                                                   Text="&#xE8BB;" />
                                    </Button>
                                </Grid>
                            </Border>

                            <TextBlock Grid.Column="1"
                                       Grid.Row="1"
                                       Margin="2,4,0,0"
                                       HorizontalAlignment="Left"
                                       FontSize="11"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="{Binding SearchResultText}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSearchActive}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <Grid DockPanel.Dock="Top"
                          Margin="0,0,0,8"
                          Visibility="{Binding ActiveViewMode, Converter={StaticResource ArchiveViewModeToVisibilityConverter}, ConverterParameter=Details}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="1.3*" />
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                                Tag="Name"
                                Click="SortHeader_OnClick"
                                Margin="0"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                HorizontalContentAlignment="Left"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MutedForegroundBrush}"
                                Content="{Binding NameSortHeader}" />
                        <Button Grid.Column="1"
                                Tag="Type"
                                Click="SortHeader_OnClick"
                                Margin="0"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                HorizontalContentAlignment="Left"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MutedForegroundBrush}"
                                Content="{Binding TypeSortHeader}" />
                        <Button Grid.Column="2"
                                Tag="Size"
                                Click="SortHeader_OnClick"
                                Margin="0"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                HorizontalContentAlignment="Right"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MutedForegroundBrush}"
                                Content="{Binding SizeSortHeader}" />
                        <Button Grid.Column="3"
                                Tag="Modified"
                                Click="SortHeader_OnClick"
                                Margin="0"
                                Padding="0"
                                BorderThickness="0"
                                Background="Transparent"
                                HorizontalContentAlignment="Right"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource MutedForegroundBrush}"
                                Content="{Binding ModifiedSortHeader}" />
                    </Grid>

                    <ListView x:Name="ItemList"
                              ItemsSource="{Binding CurrentItems}"
                              SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                              SelectionMode="Extended"
                              SelectionChanged="ItemList_OnSelectionChanged"
                              MouseDoubleClick="ItemList_OnMouseDoubleClick"
                              AllowDrop="True"
                              DragOver="ItemList_OnDragOver"
                              Drop="ItemList_OnDrop"
                              PreviewMouseLeftButtonDown="ItemList_OnPreviewMouseLeftButtonDown"
                              MouseMove="ItemList_OnMouseMove"
                              PreviewKeyDown="ItemList_OnPreviewKeyDown"
                              PreviewMouseRightButtonDown="ItemList_OnPreviewMouseRightButtonDown"
                              ScrollViewer.CanContentScroll="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                              ScrollViewer.VerticalScrollBarVisibility="Auto"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListView.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Open"
                                          Command="{Binding Data.OpenSelectedCommand, Source={StaticResource ViewModelProxy}}" />
                                <MenuItem Header="Quick Preview"
                                          InputGestureText="Space"
                                          Click="QuickPreview_OnClick" />
                                <Separator />
                                <MenuItem Header="Cut"
                                          Command="{Binding Data.CutCommand, Source={StaticResource ViewModelProxy}}" />
                                <MenuItem Header="Copy"
                                          Command="{Binding Data.CopyCommand, Source={StaticResource ViewModelProxy}}" />
                                <MenuItem Header="Paste"
                                          Command="{Binding Data.PasteCommand, Source={StaticResource ViewModelProxy}}" />
                                <Separator />
                                <MenuItem Header="Export..."
                                          Command="{Binding Data.ExportCommand, Source={StaticResource ViewModelProxy}}" />
                                <MenuItem Header="Rename..."
                                          Command="{Binding Data.RenameCommand, Source={StaticResource ViewModelProxy}}" />
                                <MenuItem Header="Delete"
                                          Command="{Binding Data.DeleteCommand, Source={StaticResource ViewModelProxy}}" />
                            </ContextMenu>
                        </ListView.ContextMenu>
                        <ListView.Style>
                            <Style TargetType="ListView" BasedOn="{StaticResource {x:Type ListView}}">
                                <Setter Property="ItemsPanel" Value="{StaticResource LinearItemsPanel}" />
                                <Setter Property="ItemTemplate" Value="{StaticResource DetailsTemplate}" />
                                <Setter Property="ItemContainerStyle" Value="{StaticResource FullRowListViewItemStyle}" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DataContext.ActiveViewMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="LargeIcons">
                                        <Setter Property="ItemsPanel" Value="{StaticResource WrapItemsPanel}" />
                                        <Setter Property="ItemTemplate" Value="{StaticResource LargeIconTemplate}" />
                                        <Setter Property="ItemContainerStyle" Value="{StaticResource IconListViewItemStyle}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.ActiveViewMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="SmallIcons">
                                        <Setter Property="ItemsPanel" Value="{StaticResource WrapItemsPanel}" />
                                        <Setter Property="ItemTemplate" Value="{StaticResource SmallIconTemplate}" />
                                        <Setter Property="ItemContainerStyle" Value="{StaticResource IconListViewItemStyle}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.ActiveViewMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="List">
                                        <Setter Property="ItemsPanel" Value="{StaticResource LinearItemsPanel}" />
                                        <Setter Property="ItemTemplate" Value="{StaticResource ListTemplate}" />
                                        <Setter Property="ItemContainerStyle" Value="{StaticResource FullRowListViewItemStyle}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding DataContext.ActiveViewMode, RelativeSource={RelativeSource AncestorType=Window}}"
                                                 Value="Details">
                                        <Setter Property="ItemsPanel" Value="{StaticResource LinearItemsPanel}" />
                                        <Setter Property="ItemTemplate" Value="{StaticResource DetailsTemplate}" />
                                        <Setter Property="ItemContainerStyle" Value="{StaticResource FullRowListViewItemStyle}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.Style>
                    </ListView>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
    </Border>
</Window>
