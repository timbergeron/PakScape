<Window x:Class="PakStudio.App.Views.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Preview"
        Width="860"
        Height="640"
        MinWidth="520"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextForegroundBrush}"
        PreviewKeyDown="Window_OnKeyDown">
    <Window.Resources>
        <Style x:Key="PreviewIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource MenuHoverBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AudioProgressSliderStyle" TargetType="Slider">
            <Setter Property="Height" Value="20" />
            <Setter Property="IsMoveToPointEnabled" Value="True" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Background="Transparent">
                            <Border Height="3"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource PanelBorderBrush}"
                                    CornerRadius="1.5" />
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.DecreaseLarge}"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3"
                                                        VerticalAlignment="Center"
                                                        Background="{DynamicResource MutedForegroundBrush}"
                                                        CornerRadius="1.5" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12" Height="12">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{DynamicResource TextForegroundBrush}"
                                                         Stroke="{DynamicResource PanelBorderBrush}"
                                                         StrokeThickness="1" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static Slider.IncreaseLarge}"
                                                  CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Focusable="False"
                                                  Background="Transparent">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.45" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="4,0,4,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="TitleText"
                           FontSize="19"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="SubtitleText"
                           Margin="0,3,0,0"
                           Foreground="{DynamicResource MutedForegroundBrush}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Width="34"
                    Height="30"
                    Margin="12,0,0,0"
                    Style="{StaticResource PreviewIconButtonStyle}"
                    ToolTip="Close preview (Space or Escape)"
                    Click="CloseButton_OnClick">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="10"
                           Text="&#xE8BB;" />
            </Button>
        </Grid>

        <Border Grid.Row="1"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                ClipToBounds="True">
            <Grid>
                <Border x:Name="ImagePanel" Background="#FF181B20" Visibility="Collapsed">
                    <Image x:Name="ImagePreview"
                           Margin="16"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True" />
                </Border>

                <TextBox x:Name="TextPreview"
                         Visibility="Collapsed"
                         Padding="14"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         FontSize="13"
                         TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto" />

                <Grid x:Name="AudioPanel" Visibility="Collapsed" Margin="30">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="96"
                                Height="96"
                                Background="{DynamicResource MenuHoverBrush}"
                                BorderBrush="{DynamicResource PanelBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="48">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="40"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="&#xE8D6;" />
                        </Border>
                        <TextBlock x:Name="AudioStatusText"
                                   Margin="0,18,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Loading audio..." />
                        <Grid Width="400" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="AudioPlayPauseButton"
                                    Width="36"
                                    Height="36"
                                    IsEnabled="False"
                                    Style="{StaticResource PreviewIconButtonStyle}"
                                    ToolTip="Play audio"
                                    Click="AudioPlayPauseButton_OnClick">
                                <TextBlock x:Name="AudioPlayPauseGlyph"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="15"
                                           Text="&#xE768;" />
                            </Button>
                            <Slider x:Name="AudioProgressSlider"
                                    Grid.Column="1"
                                    Margin="12,0"
                                    Minimum="0"
                                    Maximum="1"
                                    IsEnabled="False"
                                    Style="{StaticResource AudioProgressSliderStyle}"
                                    ValueChanged="AudioProgressSlider_OnValueChanged" />
                            <TextBlock x:Name="AudioTimeText"
                                       Grid.Column="2"
                                       MinWidth="76"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="0:00 / --:--" />
                        </Grid>
                    </StackPanel>
                </Grid>

                <Grid x:Name="MetadataPanel" Visibility="Collapsed" Margin="30">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📄" FontSize="72" HorizontalAlignment="Center" />
                        <TextBlock x:Name="MetadataTypeText"
                                   Margin="0,18,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="MetadataSizeText"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="MetadataMessageText"
                                   Margin="0,18,0,0"
                                   MaxWidth="520"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource MutedForegroundBrush}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="4,12,4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PreviousButton"
                        Style="{StaticResource PreviewIconButtonStyle}"
                        ToolTip="Previous item"
                        Click="PreviousButton_OnClick">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="11"
                               Text="&#xE72B;" />
                </Button>
                <Button x:Name="NextButton"
                        Margin="4,0,0,0"
                        Style="{StaticResource PreviewIconButtonStyle}"
                        ToolTip="Next item"
                        Click="NextButton_OnClick">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="11"
                               Text="&#xE72A;" />
                </Button>
            </StackPanel>
            <TextBlock x:Name="PositionText"
                       Grid.Column="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MutedForegroundBrush}" />
            <TextBlock Grid.Column="2"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       Text="Space or Esc to close" />
        </Grid>
    </Grid>
</Window>
