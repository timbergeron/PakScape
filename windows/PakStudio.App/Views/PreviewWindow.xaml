<Window x:Class="PakStudio.App.Views.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quick Preview"
        Width="860"
        Height="640"
        MinWidth="520"
        MinHeight="360"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextForegroundBrush}"
        PreviewKeyDown="Window_OnKeyDown">
    <Window.Resources>
        <Style x:Key="PreviewIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource MutedForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource MenuHoverBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource TextForegroundBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="4,0,4,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock x:Name="TitleText"
                           FontSize="19"
                           FontWeight="SemiBold"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="SubtitleText"
                           Margin="0,3,0,0"
                           Foreground="{DynamicResource MutedForegroundBrush}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Width="34"
                    Height="30"
                    Margin="12,0,0,0"
                    Style="{StaticResource PreviewIconButtonStyle}"
                    ToolTip="Close preview (Space or Escape)"
                    Click="CloseButton_OnClick">
                <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                           FontSize="10"
                           Text="&#xE8BB;" />
            </Button>
        </Grid>

        <Border Grid.Row="1"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="10"
                ClipToBounds="True">
            <Grid>
                <Border x:Name="ImagePanel" Background="#FF181B20" Visibility="Collapsed">
                    <Image x:Name="ImagePreview"
                           Margin="16"
                           Stretch="Uniform"
                           SnapsToDevicePixels="True" />
                </Border>

                <TextBox x:Name="TextPreview"
                         Visibility="Collapsed"
                         Padding="14"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         FontFamily="Consolas"
                         FontSize="13"
                         TextWrapping="NoWrap"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalScrollBarVisibility="Auto" />

                <Grid x:Name="MetadataPanel" Visibility="Collapsed" Margin="30">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="📄" FontSize="72" HorizontalAlignment="Center" />
                        <TextBlock x:Name="MetadataTypeText"
                                   Margin="0,18,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="MetadataSizeText"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="MetadataMessageText"
                                   Margin="0,18,0,0"
                                   MaxWidth="520"
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource MutedForegroundBrush}" />
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="4,12,4,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="PreviousButton"
                        Style="{StaticResource PreviewIconButtonStyle}"
                        ToolTip="Previous item"
                        Click="PreviousButton_OnClick">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="11"
                               Text="&#xE72B;" />
                </Button>
                <Button x:Name="NextButton"
                        Margin="4,0,0,0"
                        Style="{StaticResource PreviewIconButtonStyle}"
                        ToolTip="Next item"
                        Click="NextButton_OnClick">
                    <TextBlock FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="11"
                               Text="&#xE72A;" />
                </Button>
            </StackPanel>
            <TextBlock x:Name="PositionText"
                       Grid.Column="1"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MutedForegroundBrush}" />
            <TextBlock Grid.Column="2"
                       VerticalAlignment="Center"
                       Foreground="{DynamicResource MutedForegroundBrush}"
                       Text="Space or Esc to close" />
        </Grid>
    </Grid>
</Window>
