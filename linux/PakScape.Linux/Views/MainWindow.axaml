<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="using:PakScape.Linux.Models"
        xmlns:vm="using:PakScape.Linux.ViewModels"
        x:Class="PakScape.Linux.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding WindowTitle}"
        Icon="/Assets/pakscape.png"
        Width="1120"
        Height="720"
        MinWidth="760"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        DragDrop.AllowDrop="True"
        DragDrop.DragOver="OnDragOver"
        DragDrop.Drop="OnDrop"
        mc:Ignorable="d">
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+N" Command="{Binding NewCommand}" />
    <KeyBinding Gesture="Ctrl+O" Command="{Binding OpenCommand}" />
    <KeyBinding Gesture="Ctrl+S" Command="{Binding SaveCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+S" Command="{Binding SaveAsCommand}" />
    <KeyBinding Gesture="Ctrl+Q" Command="{Binding ExitCommand}" />
    <KeyBinding Gesture="Alt+Up" Command="{Binding UpCommand}" />
    <KeyBinding Gesture="Alt+Left" Command="{Binding BackCommand}" />
    <KeyBinding Gesture="Alt+Right" Command="{Binding ForwardCommand}" />
    <KeyBinding Gesture="F2" Command="{Binding RenameCommand}" />
    <KeyBinding Gesture="Delete" Command="{Binding DeleteCommand}" />
  </Window.KeyBindings>

  <Grid RowDefinitions="Auto,Auto,*,Auto">
    <Menu Grid.Row="0">
      <MenuItem Header="_File">
        <MenuItem Header="_New PAK" Command="{Binding NewCommand}" InputGesture="Ctrl+N" />
        <MenuItem Header="New P_K3" Command="{Binding NewPk3Command}" />
        <Separator />
        <MenuItem Header="_Open…" Command="{Binding OpenCommand}" InputGesture="Ctrl+O" />
        <MenuItem x:Name="RecentMenu" Header="Open _Recent" />
        <Separator />
        <MenuItem Header="_Save" Command="{Binding SaveCommand}" InputGesture="Ctrl+S" />
        <MenuItem Header="Save _As…" Command="{Binding SaveAsCommand}" InputGesture="Ctrl+Shift+S" />
        <Separator />
        <MenuItem Header="E_xit" Command="{Binding ExitCommand}" InputGesture="Ctrl+Q" />
      </MenuItem>
      <MenuItem Header="_Edit">
        <MenuItem Header="Cu_t" InputGesture="Ctrl+X" Click="OnCutClick" />
        <MenuItem Header="_Copy" InputGesture="Ctrl+C" Click="OnCopyClick" />
        <MenuItem Header="_Paste" InputGesture="Ctrl+V" Click="OnPasteClick" />
        <MenuItem Header="Select _All" InputGesture="Ctrl+A" Click="OnSelectAllClick" />
        <Separator />
        <MenuItem Header="New _Folder…" Command="{Binding NewFolderCommand}" />
        <MenuItem Header="_Rename…" Command="{Binding RenameCommand}" InputGesture="F2" />
        <MenuItem Header="_Delete" Command="{Binding DeleteCommand}" InputGesture="Delete" />
      </MenuItem>
      <MenuItem Header="_Go">
        <MenuItem Header="_Back" Command="{Binding BackCommand}" IsEnabled="{Binding CanGoBack}" InputGesture="Alt+Left" />
        <MenuItem Header="_Forward" Command="{Binding ForwardCommand}" IsEnabled="{Binding CanGoForward}" InputGesture="Alt+Right" />
        <MenuItem Header="_Up" Command="{Binding UpCommand}" InputGesture="Alt+Up" />
      </MenuItem>
      <MenuItem Header="_Archive">
        <MenuItem Header="Add _Files…" Command="{Binding AddFilesCommand}" />
        <MenuItem Header="Add F_older…" Command="{Binding AddFolderCommand}" />
        <MenuItem Header="_Export Selected…" Command="{Binding ExportCommand}" />
        <Separator />
        <MenuItem Header="Open in Default _Application" Command="{Binding OpenSelectedCommand}" />
      </MenuItem>
      <MenuItem Header="_View">
        <MenuItem Header="_Large Icons" Command="{Binding ShowLargeIconsCommand}" />
        <MenuItem Header="_Small Icons" Command="{Binding ShowSmallIconsCommand}" />
        <MenuItem Header="_List" Command="{Binding ShowListCommand}" />
        <MenuItem Header="_Details" Command="{Binding ShowDetailsCommand}" />
        <Separator />
        <MenuItem Header="_Quick Preview" InputGesture="Space" Click="OnQuickPreviewClick" />
      </MenuItem>
      <MenuItem Header="_Help">
        <MenuItem Header="_About PakScape" Command="{Binding AboutCommand}" />
      </MenuItem>
    </Menu>

    <Border Grid.Row="1"
            Padding="10,7"
            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*">
        <Button Grid.Column="0"
                Command="{Binding BackCommand}"
                IsEnabled="{Binding CanGoBack}"
                Content="←"
                Width="34"
                Height="30"
                ToolTip.Tip="Back (Alt+Left)"
                AutomationProperties.Name="Go back" />
        <Button Grid.Column="1"
                Margin="5,0,0,0"
                Command="{Binding ForwardCommand}"
                IsEnabled="{Binding CanGoForward}"
                Content="→"
                Width="34"
                Height="30"
                ToolTip.Tip="Forward (Alt+Right)"
                AutomationProperties.Name="Go forward" />
        <Button Grid.Column="2"
                Margin="5,0,0,0"
                Command="{Binding UpCommand}"
                Content="↑"
                Width="34"
                Height="30"
                ToolTip.Tip="Go to parent folder (Alt+Up)"
                AutomationProperties.Name="Go to parent folder" />
        <TextBlock Grid.Column="3"
                   Margin="10,0,0,0"
                   Text="{Binding CurrentFolderPath}"
                   FontFamily="monospace"
                   VerticalAlignment="Center"
                   TextTrimming="CharacterEllipsis" />
      </Grid>
    </Border>

    <Grid Grid.Row="2" ColumnDefinitions="260,6,*" Margin="10">
      <Border Grid.Column="0" Classes="panel" Padding="8">
        <Grid RowDefinitions="Auto,*">
          <TextBlock Grid.Row="0" Classes="section-title" Margin="4,2,4,8" Text="ARCHIVE" />
          <TreeView Grid.Row="1"
                    ItemsSource="{Binding FolderRoots}"
                    SelectedItem="{Binding SelectedFolder, Mode=TwoWay}"
                    AutomationProperties.Name="Archive folders">
            <TreeView.Styles>
              <Style Selector="TreeViewItem" x:CompileBindings="False">
                <Setter Property="IsExpanded" Value="{Binding IsExpanded}" />
              </Style>
            </TreeView.Styles>
            <TreeView.ItemTemplate>
              <TreeDataTemplate ItemsSource="{Binding Children}" x:DataType="models:FolderNodeViewModel">
                <StackPanel Orientation="Horizontal" Spacing="7">
                  <TextBlock Text="📁" />
                  <TextBlock Text="{Binding DisplayName}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </TreeDataTemplate>
            </TreeView.ItemTemplate>
          </TreeView>
        </Grid>
      </Border>

      <GridSplitter Grid.Column="1" ResizeDirection="Columns" Background="Transparent" />

      <Border Grid.Column="2" Classes="panel">
        <Grid>
          <ListBox x:Name="LargeIconsList"
                   IsVisible="{Binding IsLargeIconsView}"
                   ItemsSource="{Binding CurrentItems}"
                   SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                   SelectionMode="Multiple"
                   SelectionChanged="OnAlternateSelectionChanged"
                   DoubleTapped="OnAlternateItemDoubleTapped"
                   KeyDown="OnArchiveGridKeyDown"
                   PointerPressed="OnArchiveGridPointerPressed"
                   PointerMoved="OnArchiveGridPointerMoved"
                   PointerReleased="OnArchiveGridPointerReleased">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:ArchiveItemViewModel">
                <StackPanel Width="112" Margin="5" Spacing="6">
                  <Grid Width="76" Height="76" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Icon}" FontSize="42" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Image Source="{Binding Thumbnail}" Width="76" Height="76" Stretch="Uniform" />
                  </Grid>
                  <TextBlock Text="{Binding Name}" Height="38" TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <ListBox x:Name="SmallIconsList"
                   IsVisible="{Binding IsSmallIconsView}"
                   ItemsSource="{Binding CurrentItems}"
                   SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                   SelectionMode="Multiple"
                   SelectionChanged="OnAlternateSelectionChanged"
                   DoubleTapped="OnAlternateItemDoubleTapped"
                   KeyDown="OnArchiveGridKeyDown"
                   PointerPressed="OnArchiveGridPointerPressed"
                   PointerMoved="OnArchiveGridPointerMoved"
                   PointerReleased="OnArchiveGridPointerReleased">
            <ListBox.ItemsPanel>
              <ItemsPanelTemplate><WrapPanel Orientation="Horizontal" /></ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:ArchiveItemViewModel">
                <StackPanel Width="190" Margin="4" Orientation="Horizontal" Spacing="8">
                  <Grid Width="36" Height="36">
                    <TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Image Source="{Binding Thumbnail}" Width="36" Height="36" Stretch="Uniform" />
                  </Grid>
                  <TextBlock Text="{Binding Name}" Width="138" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                </StackPanel>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <ListBox x:Name="ArchiveList"
                   IsVisible="{Binding IsListView}"
                   ItemsSource="{Binding CurrentItems}"
                   SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                   SelectionMode="Multiple"
                   SelectionChanged="OnAlternateSelectionChanged"
                   DoubleTapped="OnAlternateItemDoubleTapped"
                   KeyDown="OnArchiveGridKeyDown"
                   PointerPressed="OnArchiveGridPointerPressed"
                   PointerMoved="OnArchiveGridPointerMoved"
                   PointerReleased="OnArchiveGridPointerReleased">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:ArchiveItemViewModel">
                <Grid ColumnDefinitions="36,*,150,100" Margin="5,2">
                  <Grid Grid.Column="0" Width="28" Height="28">
                    <TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    <Image Source="{Binding Thumbnail}" Width="28" Height="28" Stretch="Uniform" />
                  </Grid>
                  <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                  <TextBlock Grid.Column="2" Text="{Binding TypeText}" VerticalAlignment="Center" Opacity="0.7" />
                  <TextBlock Grid.Column="3" Text="{Binding SizeText}" VerticalAlignment="Center" Opacity="0.7" />
                </Grid>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>

          <DataGrid x:Name="ArchiveGrid"
                  IsVisible="{Binding IsDetailsView}"
                  ItemsSource="{Binding CurrentItems}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="True"
                  CanUserReorderColumns="True"
                  CanUserSortColumns="True"
                  GridLinesVisibility="Horizontal"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  DoubleTapped="OnItemDoubleTapped"
                  SelectionChanged="OnSelectionChanged"
                  AutomationProperties.Name="Archive contents">
          <DataGrid.Columns>
            <DataGridTemplateColumn Header="" Width="52" CanUserSort="False">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate x:DataType="models:ArchiveItemViewModel">
                  <Grid Width="32" Height="32" HorizontalAlignment="Center">
                    <TextBlock Text="{Binding Icon}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                    <Image Source="{Binding Thumbnail}"
                           Width="32"
                           Height="32"
                           Stretch="Uniform" />
                  </Grid>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Name" Binding="{Binding Name}" SortMemberPath="Name" Width="3*" MinWidth="180" />
            <DataGridTextColumn Header="Type" Binding="{Binding TypeText}" SortMemberPath="TypeText" Width="180" />
            <DataGridTextColumn Header="Size" Binding="{Binding SizeText}" SortMemberPath="SizeBytes" Width="110" />
            <DataGridTextColumn Header="Modified" Binding="{Binding ModifiedText}" SortMemberPath="ModifiedSortValue" Width="160" />
          </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>
    </Grid>

    <Border Grid.Row="3"
            Padding="10,6"
            BorderBrush="{DynamicResource ThemeBorderLowBrush}"
            BorderThickness="0,1,0,0">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="{Binding StatusText}" TextTrimming="CharacterEllipsis" />
        <TextBlock Grid.Column="1" Margin="20,0,0,0" Text="{Binding SelectionStatus}" />
      </Grid>
    </Border>

    <Border Grid.RowSpan="4"
            IsVisible="{Binding IsBusy}"
            Background="#44000000"
            IsHitTestVisible="True">
      <Border Background="{DynamicResource ThemeBackgroundBrush}"
              CornerRadius="8"
              Padding="22"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
        <StackPanel Spacing="12" HorizontalAlignment="Center">
          <ProgressBar IsIndeterminate="True" Width="220" />
          <TextBlock Text="{Binding StatusText}" HorizontalAlignment="Center" />
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</Window>
